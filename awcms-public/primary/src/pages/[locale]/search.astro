---
import Layout from "~/layouts/PageLayout.astro";
import SearchClient from "~/components/widgets/SearchClient";
import { t, supportedLocales, type Locale } from "~/utils/i18n";

export const prerender = true;

export function getStaticPaths() {
    return supportedLocales.map((locale) => ({
        params: { locale },
    }));
}

const { locale } = Astro.params as { locale: Locale };

const labels = {
    title: t("common.search", locale) || "Search",
    subtitle: t("search_page.subtitle", locale) || "Search results for",
    placeholder:
        t("search_page.placeholder", locale) || "Search pages, blogs...",
    button: t("common.search", locale) || "Search",
    noResults:
        t("search_page.no_results", locale) || 'No results found for "{q}".',
    readMore: t("common.read_more", locale) || "Read more",
};

const metadata = {
    title: labels.title,
    robots: {
        index: false,
        follow: true,
    },
};
---

<Layout metadata={metadata}>
    <SearchClient client:only="react" locale={locale} labels={labels} />
</Layout>
