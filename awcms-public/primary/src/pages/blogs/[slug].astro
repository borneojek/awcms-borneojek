---
import { defaultLocale } from "~/utils/i18n";
import { createClientFromEnv } from "~/lib/supabase";
import { getPublicTenantId } from "~/lib/publicTenant";

export const prerender = true;

export async function getStaticPaths() {
  const supabase = createClientFromEnv(
    import.meta.env as Record<string, string>,
  );
  if (!supabase) return [];

  const tenantId = getPublicTenantId();
  if (!tenantId) {
    throw new Error("[Blog] Missing PUBLIC_TENANT_ID for static path generation");
  }

  const { data } = await supabase
    .from("blogs")
    .select("slug")
    .eq("tenant_id", tenantId)
    .eq("status", "published")
    .is("deleted_at", null);

  return (data || []).map((blog) => ({
    params: { slug: blog.slug },
  }));
}

const { slug } = Astro.params;
---

<meta http-equiv="refresh" content={`0;url=/${defaultLocale}/blogs/${slug}`} />
<script is:inline define:vars={{ defaultLocale, slug }}>
  window.location.href = `/${defaultLocale}/blogs/${slug}`;
</script>
