---
import { createClientFromEnv } from "~/lib/supabase";
import { getPublicTenantId } from "~/lib/publicTenant";
import { Calendar, ArrowRight, Image as ImageIcon } from "lucide-react";

interface Props {
  count?: number;
  layout?: "grid" | "list";
  showImage?: boolean;
  showDate?: boolean;
  categoryFilter?: string;
  titleColor?: string;
  descriptionColor?: string;
}

const {
  count = 3,
  layout = "grid",
  showImage = true,
  showDate = true,
  categoryFilter,
  titleColor,
  descriptionColor,
} = Astro.props;

const supabase = createClientFromEnv(import.meta.env);
const tenantId = getPublicTenantId();
let blogs = [];

if (tenantId && supabase) {
  try {
    let query = supabase
      .from("blogs")
      .select("*, categories(name, slug)")
      .eq("tenant_id", tenantId)
      .eq("status", "published")
      .is("deleted_at", null)
      .order("published_at", { ascending: false })
      .limit(count);

    if (categoryFilter) {
      query = query.eq("category_id", categoryFilter);
    }

    const { data, error: err } = await query;
    if (err) throw err;

    if (data) {
      blogs = data.map((blog) => ({
        ...blog,
        main_category: blog.categories,
      }));
    }
  } catch (e) {
    console.error("[LatestBlogsBlock] Error fetching blogs:", e);
  }
}
---

{
  blogs.length === 0 ? (
    <div class="text-center p-8 bg-slate-50 dark:bg-slate-800 text-slate-500 dark:text-slate-400 rounded-lg border border-dashed border-slate-300 dark:border-slate-700">
      No blogs found.
    </div>
  ) : (
    <>
      {layout === "grid" ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 my-8">
          {blogs.map((blog) => (
        <div class="group bg-white dark:bg-slate-800 rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 flex flex-col h-full border border-slate-100 dark:border-slate-700">
              {showImage && (
                <div class="aspect-video w-full overflow-hidden bg-slate-100 dark:bg-slate-900 relative">
                  {blog.featured_image ? (
                    <img
                      src={blog.featured_image}
                      alt={blog.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-slate-300 dark:text-slate-600">
                      <ImageIcon className="w-10 h-10" client:load />
                    </div>
                  )}
                  {blog.main_category && (
                    <div class="absolute top-4 left-4">
                        <span class="bg-white/90 dark:bg-slate-800/90 backdrop-blur px-3 py-1 text-xs font-bold uppercase tracking-wider rounded-full shadow-sm text-slate-800 dark:text-slate-200">
                        {blog.main_category.name}
                       </span>
                    </div>
                  )}
                </div>
              )}
              <div class="p-6 flex flex-col flex-1">
                {showDate && blog.published_at && (
                  <div class="flex items-center gap-2 text-xs text-slate-500 dark:text-slate-400 mb-3">
                    <Calendar className="w-3 h-3" client:load />
                    {new Date(blog.published_at).toLocaleDateString("en-US", {
                      month: "long",
                      day: "numeric",
                      year: "numeric",
                    })}
                  </div>
                )}
                <h3
                  class="text-xl font-bold mb-3 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors line-clamp-2"
                  style={{ color: titleColor }}
                >
                  <a
                    href={`/blogs/${blog.slug}`}
                    class="text-slate-900 dark:text-slate-100 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
                  >
                    {blog.title}
                  </a>
                </h3>
                <p
                  class="text-sm mb-6 line-clamp-3 text-slate-600 dark:text-slate-400"
                  style={{ color: descriptionColor }}
                >
                  {blog.summary || blog.meta_description}
                </p>
                <div class="mt-auto">
                  <a
                    href={`/blogs/${blog.slug}`}
                    class="inline-flex items-center font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:no-underline group/btn"
                  >
                    Read More
                    <ArrowRight
                      className="w-4 h-4 ml-1 group-hover/btn:translate-x-1 transition-transform"
                      client:load
                    />
                  </a>
                </div>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="space-y-6 max-w-4xl mx-auto my-8">
          {blogs.map((blog) => (
            <div class="group flex flex-col md:flex-row gap-6 bg-white dark:bg-slate-800 p-4 rounded-xl shadow-sm hover:shadow-md transition-shadow border border-slate-100 dark:border-slate-700">
              {showImage && (
                <div class="w-full md:w-48 aspect-video md:aspect-square shrink-0 rounded-lg overflow-hidden bg-slate-100 dark:bg-slate-900">
                  {blog.featured_image ? (
                    <img
                      src={blog.featured_image}
                      alt={blog.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center text-slate-300 dark:text-slate-600">
                      <ImageIcon className="w-8 h-8" client:load />
                    </div>
                  )}
                </div>
              )}
              <div class="flex-1 py-1">
                <div class="flex items-center gap-3 mb-2">
                  {blog.main_category && (
                    <span class="text-xs font-bold text-blue-600 dark:text-blue-400 uppercase tracking-wider">
                      {blog.main_category.title}
                    </span>
                  )}
                  {showDate && blog.published_at && (
                    <>
                      <span class="w-1 h-1 rounded-full bg-slate-300 dark:bg-slate-600" />
                      <span class="text-xs text-slate-500 dark:text-slate-400 flex items-center gap-1">
                        <Calendar className="w-3 h-3" client:load />
                        {new Date(blog.published_at).toLocaleDateString(
                          "en-US",
                          {
                            month: "long",
                            day: "numeric",
                            year: "numeric",
                          },
                        )}
                      </span>
                    </>
                  )}
                </div>
                <h3
                  class="text-xl font-bold mb-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors"
                  style={{ color: titleColor }}
                >
                  <a
                    href={`/blogs/${blog.slug}`}
                    class="text-slate-900 dark:text-slate-100"
                  >
                    {blog.title}
                  </a>
                </h3>
                <p
                  class="text-sm mb-4 line-clamp-2 text-slate-600 dark:text-slate-400"
                  style={{ color: descriptionColor }}
                >
                  {blog.summary || blog.meta_description}
                </p>
                <a
                  href={`/blogs/${blog.slug}`}
                  class="inline-flex items-center font-semibold text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 hover:no-underline group/btn gap-1"
                >
                  Read Blog <ArrowRight className="w-4 h-4" client:load />
                </a>
              </div>
            </div>
          ))}
        </div>
      )}
    </>
  )
}
