---
/**
 * PuckRenderer.astro - Server-side renderer for Puck visual builder JSON blocks.
 *
 * Renders Puck JSON structure to semantic HTML for the public portal.
 * Supports standard and custom Puck component types.
 */

// Import Custom Blocks
import HeroBlock from "../puck-blocks/HeroBlock.astro";
import FeatureBlock from "../puck-blocks/FeatureBlock.astro";
import StatsBlock from "../puck-blocks/StatsBlock.astro";
import PricingBlock from "../puck-blocks/PricingBlock.astro";
import TestimonialBlock from "../puck-blocks/TestimonialBlock.astro";
import AccordionBlock from "../puck-blocks/AccordionBlock.astro";
import LatestBlogsBlock from "../puck-blocks/LatestBlogsBlock.astro";
import PromotionBlock from "../puck-blocks/PromotionBlock.astro";
import NavigationBlock from "../puck-blocks/NavigationBlock.astro";
import WidgetAreaBlock from "../puck-blocks/WidgetAreaBlock.astro";
import GalleryBlock from "../puck-blocks/GalleryBlock.astro";

import ContactFormBlock from "../puck-blocks/ContactFormBlock.astro";
import ServicesListBlock from "../puck-blocks/ServicesListBlock.astro";
import FeaturesListBlock from "../puck-blocks/FeaturesListBlock.astro";
import StepsBlock from "../puck-blocks/StepsBlock.astro";
import TeamListBlock from "../puck-blocks/TeamListBlock.astro";
import PartnersListBlock from "../puck-blocks/PartnersListBlock.astro";
import TestimonialsListBlock from "../puck-blocks/TestimonialsListBlock.astro";
import ButtonBlock from "../puck-blocks/ButtonBlock.astro";
import CardBlock from "../puck-blocks/CardBlock.astro";
import ContainerBlock from "../puck-blocks/ContainerBlock.astro";
import { getSanitizedRawHtml } from "./puckRendererRawHtml";
import { generateInlineStyles } from "../../utils/styleHelpers.js";

export interface Props {
  /** Puck JSON content object */
  content: PuckContent | string | null;
  /** Optional CSS class for the container */
  class?: string;
}

interface PuckContent {
  root?: {
    props?: Record<string, unknown>;
    children?: PuckBlock[];
  };
  content?: PuckBlock[];
  zones?: Record<string, PuckBlock[]>;
}

interface PuckBlock {
  type: string;
  props?: Record<string, unknown>;
}

const { content, class: className = "" } = Astro.props;

// Parse content if it's a string
let puckData: PuckContent | null = null;

if (typeof content === "string") {
  try {
    puckData = JSON.parse(content);
  } catch (e) {
    console.error("[PuckRenderer] Failed to parse content JSON:", e);
  }
} else {
  puckData = content;
}

// Block Constants
const HEADING_SIZES: Record<number, string> = {
  1: "text-4xl md:text-5xl font-bold",
  2: "text-3xl md:text-4xl font-bold",
  3: "text-2xl md:text-3xl font-semibold",
  4: "text-xl md:text-2xl font-semibold",
  5: "text-lg font-medium",
  6: "text-base font-medium",
};

// Get blocks from various possible structures
const blocks: PuckBlock[] =
  puckData?.root?.children ||
  puckData?.content ||
  puckData?.zones?.content ||
  [];
---

<div class:list={["puck-content", className]}>
  {
    blocks.map((block) => {
      const { type, props = {} } = block;

      switch (type) {
        // --- Custom Blocks ---
        case "Hero":
          return <HeroBlock {...props} />;
        case "Feature":
          return <FeatureBlock {...props} />;
        case "Stats":
          return <StatsBlock {...props} />;
        case "Pricing":
          return <PricingBlock {...props} />;
        case "Testimonial":
          return <TestimonialBlock {...props} />;
        case "Accordion":
          return <AccordionBlock {...props} />;
        case "FeaturesList":
          return <FeaturesListBlock {...props} />;
        case "Steps":
          return <StepsBlock {...props} />;
        case "LatestBlogs":
          return <LatestBlogsBlock {...props} />;
        case "Promotion":
          return <PromotionBlock {...props} />;
        case "Navigation":
          return <NavigationBlock {...props} />;
        case "WidgetArea":
          return <WidgetAreaBlock {...props} />;
        case "Gallery":
          return <GalleryBlock {...props} />;
        case "ContactForm":
          return <ContactFormBlock {...props} />;
        case "ServicesList":
          return <ServicesListBlock {...props} />;
        case "TeamList":
          return <TeamListBlock {...props} />;
        case "PartnersList":
          return <PartnersListBlock {...props} />;
        case "TestimonialsList":
          return <TestimonialsListBlock {...props} />;

        // --- Basic Blocks ---

        case "Heading":
        case "heading": {
          const level = (props.level as number) || 2;
          const text =
            (props.text as string) || (props.content as string) || "";
          const align = (props.align as string) || "left";
          // eslint-disable-next-line @typescript-eslint/no-explicit-any
          const Tag = `h${level}` as any;
          const styleStr = generateInlineStyles(props);

          return (
            <Tag
              class={`${HEADING_SIZES[level] || HEADING_SIZES[2]} text-${align} mb-4 dark:text-slate-200`}
              style={styleStr || undefined}
            >
              {text}
            </Tag>
          );
        }

        case "Text":
        case "text":
        case "Paragraph": {
          const text =
            (props.text as string) || (props.content as string) || "";
          const align = (props.align as string) || "left";
          const styleStr = generateInlineStyles(props);
          return (
            <div
              style={styleStr || undefined}
              class="awcms-advanced-style-wrapper w-full"
            >
              <p
                class={`text-lg text-slate-600 dark:text-slate-400 mb-4 text-${align}`}
              >
                {text}
              </p>
            </div>
          );
        }

        case "Image":
        case "image": {
          const src = (props.src as string) || (props.url as string) || "";
          const alt = (props.alt as string) || "";
          const caption = (props.caption as string) || "";
          const styleStr = generateInlineStyles(props);
          if (!src) return null;
          return (
            <figure class="my-6" style={styleStr || undefined}>
              <img
                src={src}
                alt={alt}
                class="w-full shadow-lg"
                loading="lazy"
                style={
                  props.borderRadius
                    ? `border-radius: ${props.borderRadius}`
                    : "border-radius: 0.75rem"
                }
              />
              {caption && (
                <figcaption class="mt-2 text-center text-sm text-slate-500 dark:text-slate-400">
                  {caption}
                </figcaption>
              )}
            </figure>
          );
        }

        case "Button":
        case "button": {
          const styleStr = generateInlineStyles(props);
          if (styleStr) {
            return (
              <div
                style={styleStr || undefined}
                class="awcms-advanced-style-wrapper w-full"
              >
                <ButtonBlock {...props} />
              </div>
            );
          }
          return <ButtonBlock {...props} />;
        }

        // --- Layout Blocks ---

        case "Columns":
        case "columns":
        case "TwoColumn": {
          // eslint-disable-next-line @typescript-eslint/no-explicit-any
          const columns = (props.columns as any[]) || [];
          const gap = (props.gap as string) || "6";
          return (
            <div class={`flex flex-col md:flex-row gap-${gap} my-6`}>
              {columns.map((col) => (
                <div class="flex-1">
                  <Astro.self content={{ content: col.items || [] }} />
                </div>
              ))}
            </div>
          );
        }

        case "Container":
        case "container": {
          // Puck passes nested DropZone children usually in the `zones` object or directly as children/content.
          // ContainerBlock uses the `content` prop.
          const containerChildren =
            (block as any).zones?.content ||
            props.content ||
            props.children ||
            [];
          return <ContainerBlock {...props} content={containerChildren} />;
        }

        case "Divider":
        case "divider":
        case "Separator":
          return <hr class="my-8 border-slate-200 dark:border-slate-700" />;

        case "Spacer":
        case "spacer": {
          const size =
            (props.size as string) || (props.height as string) || "8";
          return <div class={`h-${size}`} />;
        }

        case "Video":
        case "video": {
          const src = (props.src as string) || (props.url as string) || "";
          if (!src) return null;

          let videoContent;
          if (src.includes("youtube.com") || src.includes("youtu.be")) {
            const videoId = src.includes("youtu.be")
              ? src.split("/").pop()
              : new URL(src).searchParams.get("v");
            videoContent = (
              <iframe
                src={`https://www.youtube.com/embed/${videoId}`}
                class="w-full h-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            );
          } else {
            videoContent = (
              <video src={src} class="w-full rounded-xl shadow-lg" controls />
            );
          }

          return (
            <div class="my-6 aspect-video rounded-xl overflow-hidden shadow-lg">
              {videoContent}
            </div>
          );
        }

        case "Quote":
        case "quote":
        case "Blockquote": {
          const text =
            (props.text as string) || (props.content as string) || "";
          const author = (props.author as string) || "";
          return (
            <blockquote class="my-6 pl-6 border-l-4 border-primary">
              <p class="text-xl italic text-slate-600 dark:text-slate-300">
                "{text}"
              </p>
              {author && (
                <cite class="block mt-2 text-sm text-slate-500 dark:text-slate-400">
                  — {author}
                </cite>
              )}
            </blockquote>
          );
        }

        case "List":
        case "list": {
          const items = (props.items as string[]) || [];
          const style = (props.style as string) || "bullet";
          const Tag = style === "numbered" ? "ol" : "ul";
          const listClass = style === "numbered" ? "list-decimal" : "list-disc";
          return (
            <Tag
              class={`${listClass} list-inside space-y-2 my-4 text-slate-600 dark:text-slate-400`}
            >
              {items.map((item) => (
                <li>{item}</li>
              ))}
            </Tag>
          );
        }

        case "Code":
        case "code": {
          const code =
            (props.code as string) || (props.content as string) || "";
          const language = (props.language as string) || "";
          return (
            <pre class="my-6 p-4 bg-slate-900 text-slate-100 rounded-xl overflow-x-auto">
              <code class={`language-${language}`}>{code}</code>
            </pre>
          );
        }

        case "Card":
        case "card":
          return <CardBlock {...props} />;

        case "Html":
        case "html":
        case "RawHTML": {
          return <Fragment set:html={getSanitizedRawHtml(props)} />;
        }

        default: {
          console.warn(`[PuckRenderer] Unknown block type: ${type}`);
          return null;
        }
      }
    })
  }
</div>
